{
  "id": "elhart-emd-pump 2",
  "name": "ELHART EMD-PUMP 2",
  "description": "Преобразователь частоты для насосов",
  "connection": {
    "slaveId": 1,
    "baudRate": 9600,
    "dataBits": 8,
    "stopBits": 1,
    "parity": "none",
    "protocol": "modbus-rtu"
  },
  "images": {
    "device": "EMD-PUMP V1.x.PNG",
    "wiring": "EMD-PUMP V1.x-wiring.png"
  },
  "errorCodes": {
    "0": "Нет ошибки",
    "1": "Перегрузка по току при разгоне",
    "2": "Перегрузка по току при торможении",
    "3": "Перегрузка по току при постоянной скорости",
    "4": "Перенапряжение при разгоне",
    "5": "Перенапряжение при торможении",
    "6": "Перенапряжение при постоянной скорости",
    "7": "Пониженное напряжение шины DC",
    "8": "Перегрев преобразователя",
    "9": "Перегрев двигателя",
    "10": "Перегрузка по току двигателя",
    "11": "Перегрузка ПЧ",
    "12": "Обрыв входной фазы",
    "13": "Обрыв выходной фазы",
    "14": "Ошибка памяти EEPROM",
    "15": "Ошибка процессора",
    "16": "Ошибка связи RS-485",
    "17": "Ошибка датчика тока",
    "18": "Ошибка обратной связи ПИД",
    "19": "Потеря нагрузки",
    "20": "Ошибка автонастройки параметров двигателя",
    "23": "Перегрев радиатора",
    "24": "Короткое замыкание на землю",
    "25": "Блокировка двигателя (заклинивание)",
    "30": "Внешняя авария (вход DI)"
  },
  "alerts": [
    {
      "id": "fault-active",
      "paramId": "F0.10",
      "condition": "gt",
      "threshold": 0,
      "level": "error",
      "message": "Авария E{{value}}"
    },
    {
      "id": "temp-high",
      "paramId": "F0.08",
      "condition": "gt",
      "threshold": 70,
      "level": "warning",
      "message": "Перегрев радиатора: {{value}} °C"
    },
    {
      "id": "current-high",
      "paramId": "F0.03",
      "condition": "gt",
      "threshold": 20,
      "level": "warning",
      "message": "Высокий ток: {{value}} А"
    }
  ],
  "groups": [
    {
      "id": "f0-info",
      "name": "F0 — Информационные параметры",
      "description": "Параметры мониторинга текущего состояния ПЧ (только чтение)",
      "params": [
        {
          "id": "F0.00",
          "name": "Фактическая выходная частота",
          "register": 0,
          "access": "read",
          "type": "float",
          "scale": 0.01,
          "unit": "Гц",
          "min": 0,
          "max": 400
        },
        {
          "id": "F0.01",
          "name": "Заданная выходная частота",
          "register": 1,
          "access": "read",
          "type": "float",
          "scale": 0.01,
          "unit": "Гц",
          "min": 0,
          "max": 400
        },
        {
          "id": "F0.02",
          "name": "Выходной ток",
          "register": 2,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "А"
        },
        {
          "id": "F0.03",
          "name": "Выходное напряжение",
          "register": 3,
          "access": "read",
          "type": "integer",
          "unit": "В"
        },
        {
          "id": "F0.04",
          "name": "Напряжение звена постоянного тока",
          "register": 4,
          "access": "read",
          "type": "integer",
          "unit": "В"
        },
        {
          "id": "F0.05",
          "name": "Выходная мощность",
          "register": 5,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "кВт"
        },
        {
          "id": "F0.06",
          "name": "Скорость вращения двигателя",
          "register": 6,
          "access": "read",
          "type": "integer",
          "unit": "об/мин"
        },
        {
          "id": "F0.07",
          "name": "Заданное значение ПИД-регулятора",
          "register": 7,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "%"
        },
        {
          "id": "F0.08",
          "name": "Фактическое значение (обратная связь) ПИД-регулятора",
          "register": 8,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "%"
        },
        {
          "id": "F0.09",
          "name": "Температура радиатора ПЧ",
          "register": 9,
          "access": "read",
          "type": "integer",
          "unit": "°C"
        },
        {
          "id": "F0.10",
          "name": "Состояние дискретных входов",
          "register": 10,
          "access": "read",
          "type": "bitmask",
          "description": "bit0=FWD, bit1=REV, bit2=S1, bit3=S2, bit4=S3, bit5=S4, bit6=S5, bit7=S6"
        },
        {
          "id": "F0.11",
          "name": "Состояние дискретных выходов",
          "register": 11,
          "access": "read",
          "type": "bitmask",
          "description": "bit0=M01, bit1=M02, bit2=YA/YC, bit3-bit10=KA1-KA8"
        },
        {
          "id": "F0.12",
          "name": "Значение аналогового входа FIV",
          "register": 12,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "%"
        },
        {
          "id": "F0.13",
          "name": "Значение аналогового входа FIC",
          "register": 13,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "%"
        },
        {
          "id": "F0.14",
          "name": "Счётчик импульсов (текущее значение)",
          "register": 14,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.15",
          "name": "Длина кабеля (пробег)",
          "register": 15,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.16",
          "name": "Время работы ПЧ (накопительное)",
          "register": 16,
          "access": "read",
          "type": "integer",
          "unit": "ч"
        },
        {
          "id": "F0.17",
          "name": "Код последней аварии",
          "register": 17,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.18",
          "name": "Код предпоследней аварии",
          "register": 18,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.19",
          "name": "Код аварии 3 (третья с конца)",
          "register": 19,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.20",
          "name": "Выходная частота на момент последней аварии",
          "register": 20,
          "access": "read",
          "type": "float",
          "scale": 0.01,
          "unit": "Гц"
        },
        {
          "id": "F0.21",
          "name": "Выходной ток на момент последней аварии",
          "register": 21,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "А"
        },
        {
          "id": "F0.22",
          "name": "Напряжение звена постоянного тока на момент последней аварии",
          "register": 22,
          "access": "read",
          "type": "integer",
          "unit": "В"
        },
        {
          "id": "F0.23",
          "name": "Температура радиатора на момент последней аварии",
          "register": 23,
          "access": "read",
          "type": "integer",
          "unit": "°C"
        },
        {
          "id": "F0.24",
          "name": "Список активных аварий (битовый регистр)",
          "register": 24,
          "access": "read",
          "type": "bitmask",
          "description": "bit0=UC, bit1=OC, bit4=OU, bit6=LU, bit7=OL, bit8=OT, bit9=OH, bit10=AVI, bit11=CO, bit15=авария активна"
        },
        {
          "id": "F0.25",
          "name": "Версия программного обеспечения",
          "register": 25,
          "access": "read",
          "type": "float",
          "scale": 0.01
        },
        {
          "id": "F0.26",
          "name": "Номинальная мощность ПЧ",
          "register": 26,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "кВт"
        },
        {
          "id": "F0.27",
          "name": "Номинальный ток ПЧ",
          "register": 27,
          "access": "read",
          "type": "float",
          "scale": 0.1,
          "unit": "А"
        },
        {
          "id": "F0.28",
          "name": "Текущее состояние ПЧ",
          "register": 28,
          "access": "read",
          "type": "bitmask",
          "description": "bit0: направление (0=прямое, 1=обратное); bit1: состояние (0=стоп, 1=работа)"
        }
      ]
    },

