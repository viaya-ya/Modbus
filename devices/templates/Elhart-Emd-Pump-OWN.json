          "type": "float",
          "unit": "Гц"
        },
        {
          "id": "F0.15",
          "name": "Выходная частота в момент последней аварии",
          "register": 15,
          "access": "read",
          "type": "float",
          "unit": "Гц"
        },
        {
          "id": "F0.16",
          "name": "Выходной ток в момент последней аварии",
