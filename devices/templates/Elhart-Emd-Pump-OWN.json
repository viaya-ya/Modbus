{
  "id": "Elhart-Emd-Pump-OWN",
  "name": "Elhart-Emd-Pump-OWN",
  "description": "Преобразователь частоты для насосов (OWN)",
  "template": true,
  "connection": {
    "slaveId": 2,
    "baudRate": 9600,
    "dataBits": 8,
    "stopBits": 1,
    "parity": "none",
    "protocol": "modbus-rtu"
  },
  "images": {
    "device": "EMD-PUMP V1.x.PNG",
    "wiring": "EMD-PUMP V1.x-wiring.png"
  },
  "errorCodes": {
    "0": "Нет ошибки",
    "1": "Перегрузка по току при разгоне",
    "2": "Перегрузка по току при торможении",
    "3": "Перегрузка по току при постоянной скорости",
    "4": "Перенапряжение при разгоне",
    "5": "Перенапряжение при торможении",
    "6": "Перенапряжение при постоянной скорости",
    "7": "Пониженное напряжение шины DC",
    "8": "Перегрев преобразователя",
    "9": "Перегрев двигателя",
    "10": "Перегрузка по току двигателя",
    "11": "Перегрузка ПЧ",
    "12": "Обрыв входной фазы",
    "13": "Обрыв выходной фазы",
    "14": "Ошибка памяти EEPROM",
    "15": "Ошибка процессора",
    "16": "Ошибка связи RS-485",
    "17": "Ошибка датчика тока",
    "18": "Ошибка обратной связи ПИД",
    "19": "Потеря нагрузки",
    "20": "Ошибка автонастройки параметров двигателя",
    "23": "Перегрев радиатора",
    "24": "Короткое замыкание на землю",
    "25": "Блокировка двигателя (заклинивание)",
    "30": "Внешняя авария (вход DI)"
  },
  "alerts": [
    {
      "id": "fault-active",
      "paramId": "F0.17",
      "condition": "gt",
      "threshold": 0,
      "level": "error",
      "message": "Авария E{{value}}"
    },
    {
      "id": "temp-high",
      "paramId": "F0.09",
      "condition": "gt",
      "threshold": 70,
      "level": "warning",
      "message": "Перегрев радиатора: {{value}} °C"
    },
    {
      "id": "current-high",
      "paramId": "F0.02",
      "condition": "gt",
      "threshold": 20,
      "level": "warning",
      "message": "Высокий ток: {{value}} А"
    }
  ],
  "groups": [
    {
      "id": "vfd-control",
      "name": "Управление ПЧ",
      "description": "Регистры управления через Modbus RS-485. Источник команд F1.00=2 (RS-485), источник частоты F1.01=3 (RS-485)",
      "params": [
        {
          "id": "FREQ_SET",
          "name": "Задание выходной частоты",
          "description": "Условие: F1.01=3 (RS-485). Диапазон 0…40000 (= 0…400.00 Гц, шаг 0.01 Гц)",
          "register": 8193,
          "registerHex": "2001h",
          "access": "read-write",
          "type": "float",
          "scale": 0.01,
          "unit": "Гц",
          "min": 0,
          "max": 400,
          "default": 0
        },
        {
          "id": "CMD",
          "name": "Команды управления ПЧ",
          "description": "Условие: P102 = 2. Побитовый регистр: bit1-bit0 — пуск/стоп/JOG, bit3-bit2 — направление, bit4 — сброс аварии",
          "register": 8192,
          "registerHex": "2000h",
          "access": "read-write",
          "type": "enum",
          "options": [
            {
              "value": 0,
              "label": "Нет действия"
            },
            {
              "value": 1,
              "label": "СТОП"
            },
            {
              "value": 2,
              "label": "ПУСК"
            },
            {
              "value": 8,
              "label": "Вращение в прямом направлении"
            },
            {
              "value": 4,
              "label": "Вращение в обратном направлении"
            },
            {
              "value": 12,
              "label": "Сменить направление вращения"
            },
            {
              "value": 10,
              "label": "Вращение на частоте JOG в прямом направлении"
            },
            {
              "value": 6,
              "label": "Вращение на частоте JOG в обратном направлении"
            },
            {
              "value": 16,
              "label": "Сброс аварии"
            }
          ],
          "default": 0
        },
        {
          "id": "STATUS",
          "name": "Текущее состояние ПЧ",
          "description": "Параметр F0.28. bit0: направление (0=прямое, 1=обратное). bit1: состояние (0=стоп, 1=работа)",
          "register": 28,
          "registerHex": "001Ch",
          "paramCode": "F0.28",
          "access": "read",
          "type": "bitmask",
          "bits": [
            {
              "bit": 0,
              "name": "direction",
              "description": "Направление вращения",
              "options": {
                "0": "Прямое",
                "1": "Обратное"
              }
            },
            {
              "bit": 1,
              "name": "run",
              "description": "Состояние",
              "options": {
                "0": "Остановлен",
                "1": "Работает"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "F0",
      "name": "F0 — Информационные параметры",
      "description": "Параметры мониторинга текущего состояния ПЧ (только чтение)",
      "params": [
        {
          "id": "F0.00",
          "name": "Параметр, отображаемый на дисплее после подачи питания",
          "register": 0,
          "access": "read-write",
          "type": "enum",
          "options": {
            "0": "Заданная частота",
            "1": "Выходная частота",
            "2": "Выходной ток",
            "3": "Скорость вращения",
            "4": "Напряжение на звене постоянного тока",
            "5": "Выходное напряжение ПЧ, В",
            "6": "Раздельно отображение значений уставки (H) и обратной связи (P) ПИД-регулятора",
            "12": "Совместное отображение значений уставки (H) и обратной связи (P) ПИД-регулятора"
          },
          "default": 6
        },
        {
          "id": "F0.01",
          "name": "Заданная частота",
          "register": 1,
          "access": "read",
          "type": "float",
          "unit": "Гц"
        },
        {
          "id": "F0.02",
          "name": "Выходная частота",
          "register": 2,
          "access": "read",
          "type": "float",
          "unit": "Гц"
        },
        {
          "id": "F0.03",
          "name": "Выходной ток",
          "register": 3,
          "access": "read",
          "type": "float",
          "unit": "А"
        },
        {
          "id": "F0.04",
          "name": "Скорость вращения",
          "register": 4,
          "access": "read",
          "type": "integer",
          "unit": "об/мин"
        },
        {
          "id": "F0.05",
          "name": "Напряжение на звене постоянного тока",
          "register": 5,
          "access": "read",
          "type": "integer",
          "unit": "В"
        },
        {
          "id": "F0.06",
          "name": "Температура ПЧ",
          "register": 6,
          "access": "read",
          "type": "integer",
          "unit": "°C"
        },
        {
          "id": "F0.07",
          "name": "Значение обратной связи при использовании ПИД-регулятора",
          "register": 7,
          "access": "read",
          "type": "float"
        },
        {
          "id": "F0.08",
          "name": "Время наработки",
          "register": 8,
          "access": "read",
          "type": "integer",
          "unit": "ч"
