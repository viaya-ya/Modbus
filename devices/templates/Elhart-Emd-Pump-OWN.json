        {
          "id": "F0.09",
          "name": "Выходное напряжение ПЧ",
          "register": 9,
          "access": "read",
          "type": "integer",
          "unit": "В"
        },
        {
          "id": "F0.10",
          "name": "Последняя запись об аварии",
          "register": 10,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.11",
          "name": "2-я запись об аварии",
          "register": 11,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.12",
          "name": "3-я запись об аварии",
          "register": 12,
          "access": "read",
          "type": "integer"
        },
        {
          "id": "F0.13",
          "name": "4-я запись об аварии",
