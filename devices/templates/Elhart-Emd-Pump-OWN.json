          "register": 17,
          "access": "read",
          "type": "integer",
          "unit": "В"
        },
        {
          "id": "F0.21",
          "name": "Состояние дискретных входов в виде битовой маски",
          "register": 21,
          "access": "read",
          "type": "bitmask",
          "bits": [
            { "bit": 0, "name": "FWD", "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 1, "name": "REV", "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 2, "name": "S1",  "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 3, "name": "S2",  "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 4, "name": "S3",  "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 5, "name": "S4",  "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 6, "name": "S5",  "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 7, "name": "S6",  "options": { "0": "выкл", "1": "вкл" } }
          ]
        },
        {
          "id": "F0.22",
          "name": "Состояние дискретных выходов в виде битовой маски",
          "register": 22,
          "access": "read",
          "type": "bitmask",
          "bits": [
            { "bit": 0,  "name": "M01", "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 1,  "name": "M02", "options": { "0": "выкл", "1": "вкл" } },
            { "bit": 2,  "name": "YA/YC", "options": { "0": "выкл", "1": "вкл" } }
          ]
        },
        {
          "id": "F0.23",
          "name": "Значение сигнала на входе FIV",
